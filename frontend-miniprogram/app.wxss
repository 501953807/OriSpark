/* app.wxss */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial,
    'Noto Sans', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #333;
  background-color: #f9fafb;
  line-height: 1.5;
}

.container {
  padding: 24rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  color: #111827;
}

.loading-text {
  text-align: center;
  color: #9ca3af;
  padding: 60rpx 0;
}

.error-text {
  text-align: center;
  color: #ef4444;
  padding: 60rpx 0;
}

.empty-text {
  text-align: center;
  color: #9ca3af;
  padding: 60rpx 0;
}

.btn-primary {
  background: #059669;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #fff;
  color: #059669;
  border: 2rpx solid #059669;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}

.btn-secondary::after {
  border: none;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin: 24rpx 0 16rpx;
  color: #111827;
}

.empty-state {
  text-align: center;
  color: #9ca3af;
  padding: 60rpx 0;
  font-size: 28rpx;
}
