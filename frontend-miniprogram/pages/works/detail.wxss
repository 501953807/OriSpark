/* pages/works/detail.wxss */
.container { padding: 24rpx; }
.loading-text, .empty-state { text-align: center; padding: 80rpx 0; color: #9ca3af; }
.detail-section { background: #fff; border-radius: 16rpx; overflow: hidden; box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.06); }
.work-image { width: 100%; height: 600rpx; }
.work-title { font-size: 36rpx; font-weight: bold; padding: 24rpx 24rpx 8rpx; }
.work-category { font-size: 24rpx; color: #6b7280; padding: 0 24rpx; margin-bottom: 16rpx; }
.work-desc { font-size: 28rpx; color: #374151; line-height: 1.6; padding: 0 24rpx 24rpx; }
