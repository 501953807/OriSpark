/* pages/chat/index.wxss */
.session-list { padding: 16rpx; }
.session-item { background: #fff; padding: 24rpx; margin-bottom: 8rpx; border-radius: 12rpx; }
.session-name { font-size: 30rpx; font-weight: 500; display: block; }
.session-last { font-size: 26rpx; color: #666; display: block; margin-top: 8rpx; }
.session-time { font-size: 22rpx; color: #999; display: block; margin-top: 8rpx; text-align: right; }
