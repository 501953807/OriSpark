/* pages/contracts/detail.wxss */
.container { padding: 24rpx; }
.loading-text, .empty-state { text-align: center; padding: 80rpx 0; color: #9ca3af; }
.detail-section { background: #fff; border-radius: 16rpx; padding: 32rpx; box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.06); }
.detail-title { font-size: 36rpx; font-weight: bold; margin-bottom: 16rpx; }
.detail-meta { display: flex; align-items: center; gap: 16rpx; margin-bottom: 24rpx; }
.status-badge { font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 8rpx; }
.status-badge.active { background: #e8f5e9; color: #2e7d32; }
.status-badge.pending { background: #fff3e0; color: #e65100; }
.status-badge.listed { background: #e3f2fd; color: #1565c0; }
.detail-type { font-size: 24rpx; color: #6b7280; }
.detail-amount { background: #f9fafb; border-radius: 12rpx; padding: 24rpx; margin-bottom: 24rpx; }
.amount-label { font-size: 24rpx; color: #6b7280; display: block; }
.amount-value { font-size: 40rpx; font-weight: bold; color: #1a237e; display: block; margin-top: 4rpx; }
.detail-desc { margin-bottom: 24rpx; }
.desc-label { font-size: 26rpx; font-weight: 500; color: #374151; display: block; margin-bottom: 8rpx; }
.desc-text { font-size: 28rpx; color: #4b5563; line-height: 1.6; }
.detail-scope { margin-bottom: 24rpx; }
.scope-label { font-size: 26rpx; font-weight: 500; color: #374151; display: block; margin-bottom: 12rpx; }
.scope-row { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid #f3f4f6; }
.scope-key { font-size: 26rpx; color: #6b7280; }
.detail-footer { margin-top: 32rpx; }
.btn-primary { background: #059669; color: #fff; border: none; border-radius: 12rpx; padding: 20rpx 0; font-size: 28rpx; font-weight: 500; }
