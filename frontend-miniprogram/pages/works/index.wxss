/* pages/works/index.wxss */
.works-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.work-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.1);
}

.work-thumb {
  width: 100%;
  height: 300rpx;
  background: #f3f4f6;
}

.work-name {
  font-size: 24rpx;
  color: #374151;
  padding: 12rpx 16rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
