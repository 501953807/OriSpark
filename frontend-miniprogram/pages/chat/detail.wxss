/* pages/chat/detail.wxss */
.chat-detail { display: flex; flex-direction: column; height: 100vh; }
.message-list { flex: 1; padding: 16rpx; }
.message { max-width: 80%; padding: 20rpx; border-radius: 12rpx; margin-bottom: 16rpx; }
.message.received { background: #fff; align-self: flex-start; }
.message.sent { background: #1a237e; color: #fff; margin-left: auto; }
.msg-text { font-size: 28rpx; }
.msg-time { font-size: 22rpx; color: #999; margin-top: 8rpx; display: block; }
.chat-input { display: flex; padding: 16rpx; border-top: 1rpx solid #eee; }
.input-field { flex: 1; border: 1rpx solid #ddd; border-radius: 8rpx; padding: 0 20rpx; font-size: 28rpx; }
.btn-small { padding: 0 30rpx; margin-left: 16rpx; }
