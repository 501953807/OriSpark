# OriStudio 环境配置示例
# 复制此文件为 .env 并根据需要修改

# 应用配置
APP_NAME=OriStudio
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=change-me-to-a-random-string

# 数据库
DATABASE_URL=sqlite:///./data/oristudio.db

# Redis (Celery 消息代理)
REDIS_URL=redis://localhost:6379/0

# 服务器
HOST=127.0.0.1
PORT=8765

# 工作区路径 (默认为用户目录下的 OriStudio)
WORKSPACE_PATH=~/OriStudio/workspace

# 外部 API (可选，在 Settings 页面配置)
# BANQUANJIA_API_KEY=
# BANQUANJIA_API_SECRET=
# ANTCHAIN_API_KEY=
# ANTCHAIN_API_SECRET=
# ZHIXINCHAIN_API_KEY=
# ZHIXINCHAIN_API_SECRET=
# BAIDU_VISION_API_KEY=
# GOOGLE_VISION_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
