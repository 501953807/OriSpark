#!/usr/bin/env bash
# OriStudio centralized configuration — source this file from all scripts

# Project root (auto-detected)
export ORI_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Backend
export BACKEND_DIR="$ORI_ROOT/backend"
export BACKEND_PORT="${BACKEND_PORT:-8001}"
export BACKEND_HOST="${BACKEND_HOST:-127.0.0.1}"

# Frontend Web
export FRONTEND_WEB_DIR="$ORI_ROOT/frontend-web"
export FRONTEND_PORT="${FRONTEND_PORT:-5174}"

# Nuxt Portal
export FRONTEND_NUXT_DIR="$ORI_ROOT/frontend-nuxt"
export PORTAL_PORT="${PORTAL_PORT:-3000}"

# Electron Desktop
export ELECTRON_DIR="$ORI_ROOT/frontend-electron"

# WeChat Mini Program
export MINIPROGRAM_DIR="$ORI_ROOT/frontend-miniprogram"

# Celery & Redis
export REDIS_PORT="${REDIS_PORT:-6379}"
export REDIS_HOST="${REDIS_HOST:-127.0.0.1}"
export CELERY_REDIS_URL="redis://${REDIS_HOST}:${REDIS_PORT}/0"

# Database
export DATABASE_URL="sqlite+aiosqlite:///./data/oristudio.db"

# Python / Node
export PYTHON_BIN="${PYTHON_BIN:-python3}"
export NODE_BIN="${NODE_BIN:-node}"
export NPM_BIN="${NPM_BIN:-npm}"

# Colors for output
export ANSI_RESET="\033[0m"
export ANSI_GREEN="\033[32m"
export ANSI_YELLOW="\033[33m"
export ANSI_RED="\033[31m"
export ANSI_CYAN="\033[36m"
